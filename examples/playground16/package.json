{
	"name": "playground16",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev --webpack",
		"build": "next build --webpack",
		"start": "next start",
		"lint": "eslint",
		"build:worker": "pnpm opennextjs-cloudflare build",
		"preview:worker": "pnpm opennextjs-cloudflare preview",
		"preview": "pnpm build:worker && pnpm preview:worker",
		"e2e": "playwright test -c e2e/playwright.config.ts",
		"e2e:dev": "playwright test -c e2e/playwright.dev.config.ts",
		"build:worker-turbopack": "pnpm build:worker --openNextConfigPath open-next.turbopack.config.ts",
		"e2e-turbopack": "playwright test -c e2e/playwright.turbopack.config.ts",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv"
	},
	"dependencies": {
		"@mathjax/mathjax-fira-font": "^4.1.1",
		"@mathjax/src": "4.1.1",
		"@mdx-js/mdx": "^3.1.1",
		"next": "16.2.3",
		"react-dom": "19.2.4",
		"react": "19.2.4",
		"rehype-mathjax": "github:jajaperson/remark-math#mathjax4&path:packages/rehype-mathjax",
		"remark-math": "^6.0.0",
		"shiki": "3.22.0"
	},
	"devDependencies": {
		"@opennextjs/cloudflare": "workspace:*",
		"@playwright/test": "catalog:",
		"@tailwindcss/postcss": "^4",
		"@types/node": "catalog:",
		"@types/react-dom": "^19.2.3",
		"@types/react": "^19.2.4",
		"tailwindcss": "^4",
		"wrangler": "catalog:"
	}
}
